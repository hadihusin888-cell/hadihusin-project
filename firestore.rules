rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Global safety net: Deny all by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Reuseable global helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/adminConfigs/config) && 
        get(/databases/$(database)/documents/adminConfigs/config).data.adminPassword != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 64 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // 2. Classes Rules
    match /classes/{classId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // 3. Subjects (Mapel) Rules
    match /subjects/{subjectId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // 4. Teachers Rules
    match /teachers/{teacherId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || (isSignedIn() && request.auth.uid == teacherId);
    }

    // 5. Students Rules
    match /students/{studentId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || (isSignedIn() && request.auth.uid == studentId);
    }

    // 6. Materials Rules
    match /materials/{materialId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && (
        exists(/databases/$(database)/documents/teachers/$(request.auth.uid))
      );
      allow delete: if isAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/teachers/$(request.auth.uid)));
    }

    // 7. Assignments Rules
    match /assignments/{assignmentId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && (
        exists(/databases/$(database)/documents/teachers/$(request.auth.uid))
      );
      allow delete: if isAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/teachers/$(request.auth.uid)));
    }

    // 8. Grades and Submissions Rules
    match /grades/{gradeId} {
      allow read: if isSignedIn();
      
      // Permit students to submit and update only their own grades
      allow create, update: if isSignedIn() && (
        exists(/databases/$(database)/documents/teachers/$(request.auth.uid)) ||
        (request.resource.data.studentId == request.auth.uid)
      );
      allow delete: if isAdmin();
    }

    // 9. Admin Configs Rules
    match /adminConfigs/{configId} {
      allow read, write: if isAdmin();
    }
  }
}
